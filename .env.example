# ══════════════════════════════════════════════════════════════════
# Official AI — Environment Variables
# Copy to .env.local for local dev. Set in Vercel/Railway for prod.
# ══════════════════════════════════════════════════════════════════

# ── Database (PostgreSQL via Supabase) ────────────────────────────
DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

# ── Auth (NextAuth) ───────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="GENERATE_A_REAL_SECRET"
NEXTAUTH_URL="http://localhost:3000"
# DEV_AUTH_BYPASS="true"  ← uncomment ONLY for local dev

# ── Supabase Storage ─────────────────────────────────────────────
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."

# ── FAL AI (video generation) ────────────────────────────────────
FAL_API_KEY=""
FAL_WEBHOOK_SECRET=""

# ── ElevenLabs (voice cloning) ───────────────────────────────────
ELEVENLABS_API_KEY=""

# ── Google AI Studio (Gemini) ────────────────────────────────────
GOOGLE_AI_STUDIO_KEY=""

# ── OpenRouter (Claude research agents) ──────────────────────────
OPENROUTER_API_KEY=""

# ── Exa (semantic search) ────────────────────────────────────────
EXA_API_KEY=""

# ── Firecrawl (web scraping) ─────────────────────────────────────
FIRECRAWL_API_KEY=""

# ── PostBridge (social publishing) ───────────────────────────────
POST_BRIDGE_API_KEY=""

# ── Social OAuth ─────────────────────────────────────────────────
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ── Email (SendGrid SMTP) ───────────────────────────────────────
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="SG..."
EMAIL_FROM="notifications@theofficial.ai"

# ── Admin ────────────────────────────────────────────────────────
ADMIN_EMAILS="kayan@theofficial.ai,dave@theofficial.ai"

# ── Cron ─────────────────────────────────────────────────────────
CRON_SECRET=""

# ── Sentry (error tracking) ─────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ── App URL ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

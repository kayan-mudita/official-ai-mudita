# ══════════════════════════════════════════════════════════════════
# Official AI — Environment Variables
# Copy to .env.local for local dev. Set in Vercel/Railway for prod.
# ══════════════════════════════════════════════════════════════════

# ── Database (PostgreSQL via Supabase) ────────────────────────────
DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

# ── Auth (NextAuth) ───────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="GENERATE_A_REAL_SECRET"
NEXTAUTH_URL="http://localhost:3000"
# DEV_AUTH_BYPASS="true"  ← uncomment ONLY for local dev

# ── Supabase Storage ─────────────────────────────────────────────
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."

# ══════════════════════════════════════════════════════════════════
# GENERATION PROVIDERS (consolidated — only 4 keys needed)
# ══════════════════════════════════════════════════════════════════

# ── FAL AI (PRIMARY — video + TTS + upscale + transcription) ─────
# One key handles: 15 video models, MiniMax TTS, Real-ESRGAN upscale,
# Whisper transcription. This is the only REQUIRED generation key.
FAL_API_KEY=""
FAL_WEBHOOK_SECRET=""

# ── ElevenLabs (voice cloning ONLY) ──────────────────────────────
# Only needed for voice cloning. TTS works via FAL without this.
ELEVENLABS_API_KEY=""

# ── HeyGen (premium avatar track — OPTIONAL) ─────────────────────
# Only needed for HeyGen Avatar V/IV. All other models work via FAL.
HEYGEN_API_KEY=""

# ── Shotstack (video stitching — OPTIONAL for multi-cut) ─────────
# Only needed for multi-cut videos. Hook-only mode doesn't need this.
# SHOTSTACK_API_KEY=""

# ══════════════════════════════════════════════════════════════════
# AI AGENTS (research + content planning)
# ══════════════════════════════════════════════════════════════════

# ── Google AI Studio (Gemini — content planning, character sheets) ─
GOOGLE_AI_STUDIO_KEY=""

# ── OpenRouter (Claude — research agents with MCP tools) ─────────
OPENROUTER_API_KEY=""

# ── Exa (semantic search for research agents) ────────────────────
EXA_API_KEY=""

# ── Firecrawl (web scraping for research agents) ─────────────────
FIRECRAWL_API_KEY=""

# ══════════════════════════════════════════════════════════════════
# PUBLISHING + SOCIAL
# ══════════════════════════════════════════════════════════════════

# ── PostBridge (social publishing) ───────────────────────────────
POST_BRIDGE_API_KEY=""

# ── Social OAuth ─────────────────────────────────────────────────
INSTAGRAM_CLIENT_ID=""
INSTAGRAM_CLIENT_SECRET=""
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ══════════════════════════════════════════════════════════════════
# INFRASTRUCTURE
# ══════════════════════════════════════════════════════════════════

# ── Email (SendGrid SMTP) ───────────────────────────────────────
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="SG..."
EMAIL_FROM="notifications@theofficial.ai"

# ── Admin ────────────────────────────────────────────────────────
ADMIN_EMAILS="kayan@theofficial.ai,dave@theofficial.ai"

# ── Cron ─────────────────────────────────────────────────────────
CRON_SECRET=""

# ── Sentry (error tracking) ─────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ── App URL ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Public site URL (canonical / OG / schema / sitemap) ─────────
# Drives every canonical tag, OG URL, JSON-LD @id/url, sitemap entry,
# robots.txt Sitemap directive, and llms.txt links. Must match the
# live production domain exactly. Do NOT set this in local dev.
NEXT_PUBLIC_SITE_URL="https://www.theofficial.ai"
